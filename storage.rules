
rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files.
    // This is safe because file URLs are unguessable.
    match /{allPaths=**} {
      allow read;
    }

    // Allow authenticated users to write to their own user-specific directory.
    // The path ensures that a user can only upload files into a folder
    // that matches their own UID.
    match /users/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
